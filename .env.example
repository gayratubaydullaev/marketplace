# Database — never commit real credentials
DATABASE_URL=postgres://CHANGE_ME:CHANGE_ME@localhost:5432/marketplace?sslmode=require
REDIS_URL=redis://:CHANGE_ME@localhost:6379/0
KAFKA_BROKERS=localhost:9092
ELASTICSEARCH_URL=http://localhost:9200
CLICKHOUSE_URL=http://localhost:8123
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=marketplace
MINIO_SECURE=true

# JWT: set PEM for RS256 production; JWT_SECRET used only as HS256 fallback in development
JWT_SECRET=CHANGE_ME_USE_RS256_IN_PROD
# JWT_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_KID=gayrat-rs256-1
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
APP_ENV=development

DEFAULT_LOCALE=uz
DEFAULT_CURRENCY=UZS

# Frontend — single gateway (Kong or scripts/dev-gateway.sh)
NEXT_PUBLIC_API_BASE=http://localhost:8080
NEXT_PUBLIC_TENANT_ID=00000000-0000-0000-0000-000000000001
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3000

# Payments (sandbox shaped — no live money)
PAYMENTS_SANDBOX=true
PAYMENTS_PUBLIC_BASE=http://localhost:8006
PAYME_MERCHANT_ID=gayrat-payme
CLICK_MERCHANT_ID=gayrat-click
UZUM_MERCHANT_ID=gayrat-uzum
STRIPE_SECRET=sk_test_dev
PAYME_SECRET=CHANGE_ME
CLICK_SECRET=CHANGE_ME
UZUM_SECRET=CHANGE_ME
STRIPE_WEBHOOK_SECRET=CHANGE_ME
PAYPAL_CLIENT_ID=CHANGE_ME
PAYPAL_CLIENT_SECRET=CHANGE_ME

# OAuth and messaging integrations
GOOGLE_OAUTH_CLIENT_ID=CHANGE_ME
APPLE_OAUTH_CLIENT_ID=CHANGE_ME
FACEBOOK_APP_ID=CHANGE_ME
FACEBOOK_APP_SECRET=CHANGE_ME
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_FROM=CHANGE_ME
ESKIZ_EMAIL=CHANGE_ME
ESKIZ_PASSWORD=CHANGE_ME
ESKIZ_FROM=CHANGE_ME

# Operations
CORS_ORIGINS=http://localhost:3000
SENTRY_DSN=
CENTRIFUGO_WS_URL=ws://localhost:8000/connection/websocket
